<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="250dp"
        android:layout_height="250dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.3" >

    </androidx.camera.view.PreviewView>

    <EditText
        android:id="@+id/upiIDField"
        android:layout_width="277dp"
        android:layout_height="41dp"
        android:layout_marginTop="50dp"
        android:hint="Mobile Number / UPI ID"
        android:inputType="text"
        android:textAlignment="center"
        android:textColorHint="#CCCCCC"
        app:layout_constraintEnd_toEndOf="@+id/viewFinder"
        app:layout_constraintStart_toStartOf="@+id/viewFinder"
        app:layout_constraintTop_toBottomOf="@+id/viewFinder" />

    <Button
        android:id="@+id/button"
        android:layout_width="175dp"
        android:layout_height="62dp"
        android:layout_marginTop="12dp"
        android:text="Make Payment"
        app:layout_constraintEnd_toEndOf="@+id/upiIDField"
        app:layout_constraintStart_toStartOf="@+id/upiIDField"
        app:layout_constraintTop_toBottomOf="@+id/upiIDField" />

    <Button
        android:id="@+id/bal_button"
        android:layout_width="175dp"
        android:layout_height="62dp"
        android:layout_marginTop="88dp"
        android:text="Check Balance"
        app:layout_constraintEnd_toEndOf="@+id/upiIDField"
        app:layout_constraintStart_toStartOf="@+id/upiIDField"
        app:layout_constraintTop_toBottomOf="@+id/upiIDField" />

    <TextView
        android:id="@+id/signal_stats_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="challagalestundi"
        android:textColor="#FFFFFF"
        tools:layout_editor_absoluteX="20dp"
        tools:layout_editor_absoluteY="20dp" />

    <ImageButton
        android:id="@+id/settings_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="7dp"
        android:layout_marginRight="7dp"
        android:adjustViewBounds="true"
        android:backgroundTint="#000000"
        android:paddingRight="10dp"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/settings_icon_512" />

    <ImageButton
        android:id="@+id/history_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:backgroundTint="#000000"
        android:padding="12dp"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="@id/settings_button"
        app:layout_constraintTop_toBottomOf="@id/settings_button"
        app:srcCompat="@drawable/history_icon_512" />

</androidx.constraintlayout.widget.ConstraintLayout>