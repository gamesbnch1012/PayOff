<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="250dp"
        android:layout_height="250dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.3" >

    </androidx.camera.view.PreviewView>

    <LinearLayout
        android:layout_width="325dp"
        android:layout_height="50dp"
        app:layout_constraintEnd_toEndOf="@+id/viewFinder"
        app:layout_constraintStart_toStartOf="@+id/viewFinder"
        app:layout_constraintTop_toBottomOf="@+id/viewFinder"
        android:layout_marginTop="50dp">
        <EditText
            android:id="@+id/upiIDField"
            android:layout_width="275dp"
            android:layout_height="50dp"
            android:hint="Mobile Number / UPI ID"
            android:inputType="text"
            android:textAlignment="center"
            android:textColorHint="#CCCCCC"
             />

        <Button
            android:id="@+id/button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:clickable="true"
            android:enabled="true"
            android:text="👤"
            app:layout_constraintBottom_toBottomOf="@id/upiIDField"
            app:layout_constraintEnd_toEndOf="@+id/upiIDField"
            app:layout_constraintStart_toEndOf="@+id/upiIDField"
            app:layout_constraintTop_toTopOf="@+id/upiIDField" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👤" />
    </LinearLayout>

    <Button
        android:id="@+id/bal_button"
        android:layout_width="175dp"
        android:layout_height="62dp"
        android:layout_marginTop="120dp"
        android:hapticFeedbackEnabled="true"
        android:text="Check Balance"
        app:layout_constraintEnd_toEndOf="@+id/viewFinder"
        app:layout_constraintStart_toStartOf="@+id/viewFinder"
        app:layout_constraintTop_toBottomOf="@+id/viewFinder" />

    <TextView
        android:id="@+id/signal_stats_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="challagalestundi"
        android:textColor="#FFFFFF"
        tools:layout_editor_absoluteX="20dp"
        tools:layout_editor_absoluteY="20dp" />

    <ImageButton
        android:id="@+id/settings_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="7dp"
        android:layout_marginRight="7dp"
        android:adjustViewBounds="true"
        android:backgroundTint="#000000"
        android:paddingRight="10dp"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/settings_icon_512" />

    <ImageButton
        android:id="@+id/history_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:backgroundTint="#000000"
        android:padding="12dp"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="@id/settings_button"
        app:layout_constraintTop_toBottomOf="@id/settings_button"
        app:srcCompat="@drawable/history_icon_512" />

    <ImageButton
        android:id="@+id/show_qr_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:backgroundTint="#000000"
        android:padding="12dp"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="@id/history_button"
        app:layout_constraintTop_toBottomOf="@id/history_button"
        app:srcCompat="@drawable/qr_code_icon_512" />

    <ImageButton
        android:id="@+id/favourites_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:backgroundTint="#000000"
        android:foregroundTintMode="add"
        android:padding="12dp"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="@id/show_qr_button"
        app:layout_constraintTop_toBottomOf="@id/show_qr_button"
        app:srcCompat="@drawable/star_icon_1024" />

</androidx.constraintlayout.widget.ConstraintLayout>